APP_NAME=Personal AI Agent
APP_ENVIRONMENT=development
APP_HOST=0.0.0.0
APP_PORT=8000

TELEGRAM_BOT_TOKEN=replace-with-your-bot-token
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_POLLING_ENABLED=true
TELEGRAM_POLL_TIMEOUT_SECONDS=10
TELEGRAM_POLL_INTERVAL_SECONDS=1.0
TELEGRAM_ALLOWED_CHAT_IDS=

GEMINI_API_KEY=replace-later
GEMINI_MODEL=replace-later

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/personal_ai_agent
